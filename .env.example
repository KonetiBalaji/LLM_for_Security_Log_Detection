# LLM API Configuration
SENTINEL_LLM_PROVIDER=openai
SENTINEL_OPENAI_API_KEY=sk-your-key-here
SENTINEL_LLM_MODEL=gpt-4o-mini

# Application Settings
SENTINEL_LOG_LEVEL=INFO
SENTINEL_MAX_UPLOAD_SIZE_MB=50
SENTINEL_AUTH_ENABLED=false
SENTINEL_AUTH_TOKEN=change-me-in-production

# Model Paths
SENTINEL_BERT_MODEL_NAME=all-MiniLM-L6-v2
